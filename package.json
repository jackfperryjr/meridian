{
  "name": "meridian",
  "version": "0.0.0",
  "description": "Meridian — A modern DragonRealms front-end",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.3",
    "jotai": "^2.8.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "jimp": "^0.22.12",
    "potrace": "^2.1.8",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  },
  "build": {
    "appId": "com.meridian.dragonrealms",
    "productName": "Meridian",
    "icon": "resources/icon.png",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "jackfperryjr",
      "repo": "meridian"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
